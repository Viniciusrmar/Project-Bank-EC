  "exemplos_erro_validacao": {
    "cadastro_nome_curto": {
      "body": { "nome": "Ana", "email": "ana@email.com", "senha": "123", "data_nascimento": "2000-01-01", "cpf": "111", "cep": "11111" },
      "resposta_400": { "erros": ["Nome deve ter no mínimo 5 caracteres."] }
    },
    "cadastro_menor_de_idade": {
      "body": { "nome": "Carlos Silva", "email": "carlos@email.com", "senha": "123456", "data_nascimento": "2010-05-10", "cpf": "222.333.444-55", "cep": "01310-100" },
      "resposta_400": { "erros": ["Usuário deve ter pelo menos 18 anos."] }
    },
    "transacao_saldo_insuficiente": {
      "body": { "conta_id": 1, "tipo_transacao": "SAIDA", "valor": 99999.00 },
      "resposta_422": { "erro": "Saldo insuficiente para esta transação." }
    }
  }
